# kragen-service environment template (single source for secrets/overrides)
# Copy to /etc/kragen/kragen-service.env and adjust values.

# Core auth behavior for API process
KRAGEN_AUTH__DISABLED=false

# Database
KRAGEN_DATABASE__URL=postgresql+asyncpg://kragen:CHANGE_ME@127.0.0.1:5432/kragen

# Object storage (MinIO / S3)
KRAGEN_STORAGE__ENDPOINT_URL=http://127.0.0.1:9000
KRAGEN_STORAGE__ACCESS_KEY=CHANGE_ME
KRAGEN_STORAGE__SECRET_KEY=CHANGE_ME
KRAGEN_STORAGE__BUCKET=kragen

# Telegram channel runtime
KRAGEN_TELEGRAM_BOT_TOKEN=1234567890:TEST_BOT_TOKEN_REPLACE_ME
KRAGEN_TELEGRAM_API_BASE_URL=http://127.0.0.1:8000
KRAGEN_TELEGRAM_AUTH_USER_ID=00000000-0000-0000-0000-000000001111
KRAGEN_TELEGRAM_DEFAULT_WORKSPACE_ID=00000000-0000-0000-0000-000000001111
KRAGEN_TELEGRAM_MODE=polling

# Optional tuneables
# KRAGEN_TELEGRAM_POLL_TIMEOUT_SECONDS=20
# KRAGEN_TELEGRAM_LOOP_DELAY_SECONDS=0.4
# KRAGEN_TELEGRAM_TASK_POLL_INTERVAL_SECONDS=1.0
# KRAGEN_TELEGRAM_TASK_WAIT_TIMEOUT_SECONDS=300
# KRAGEN_TELEGRAM_DEDUP_RETENTION_HOURS=168
# KRAGEN_TELEGRAM_DEDUP_CLEANUP_INTERVAL_SECONDS=3600

# Webhook mode settings (used when KRAGEN_TELEGRAM_MODE=webhook)
# KRAGEN_TELEGRAM_WEBHOOK_PUBLIC_URL=https://bot.example.com
# KRAGEN_TELEGRAM_WEBHOOK_PATH=/telegram/webhook
# KRAGEN_TELEGRAM_WEBHOOK_HOST=127.0.0.1
# KRAGEN_TELEGRAM_WEBHOOK_PORT=8081
# KRAGEN_TELEGRAM_WEBHOOK_SECRET_TOKEN=REPLACE_ME
