# kragen-service environment template
# Copy to /etc/kragen/kragen-service.env and adjust values.
# This file is loaded by scripts/systemd/kragen-service.service.

# Optional explicit config path (if not set in unit directly):
# KRAGEN_CONFIG_FILE=/etc/kragen/kragen.yaml

# -------- Telegram adapter runtime --------
# These values override telegram_channel.* from kragen.yaml.

# Required for Telegram integration:
KRAGEN_TELEGRAM_BOT_TOKEN=1234567890:TEST_BOT_TOKEN_REPLACE_ME
KRAGEN_TELEGRAM_API_BASE_URL=http://127.0.0.1:8000
KRAGEN_TELEGRAM_AUTH_USER_ID=00000000-0000-0000-0000-000000000001
KRAGEN_TELEGRAM_DEFAULT_WORKSPACE_ID=00000000-0000-0000-0000-000000000001

# Mode: polling | webhook
KRAGEN_TELEGRAM_MODE=polling

# Polling tuneables
KRAGEN_TELEGRAM_POLL_TIMEOUT_SECONDS=20
KRAGEN_TELEGRAM_LOOP_DELAY_SECONDS=0.4
KRAGEN_TELEGRAM_TASK_POLL_INTERVAL_SECONDS=1.0
KRAGEN_TELEGRAM_TASK_WAIT_TIMEOUT_SECONDS=300

# Dedup retention / cleanup
KRAGEN_TELEGRAM_DEDUP_RETENTION_HOURS=168
KRAGEN_TELEGRAM_DEDUP_CLEANUP_INTERVAL_SECONDS=3600

# Webhook settings (used when KRAGEN_TELEGRAM_MODE=webhook)
# KRAGEN_TELEGRAM_WEBHOOK_PUBLIC_URL=https://bot.example.com
# KRAGEN_TELEGRAM_WEBHOOK_PATH=/telegram/webhook
# KRAGEN_TELEGRAM_WEBHOOK_HOST=127.0.0.1
# KRAGEN_TELEGRAM_WEBHOOK_PORT=8081
# KRAGEN_TELEGRAM_WEBHOOK_SECRET_TOKEN=TEST_WEBHOOK_SECRET_REPLACE_ME
