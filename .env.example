# Optional: load secrets/overrides (YAML remains the main config file).
# All variables use prefix KRAGEN_ and __ for nested keys (see configs/kragen.yaml).
#
# KRAGEN_CONFIG_FILE=/absolute/path/to/kragen.yaml

# Examples (uncomment and set as needed):
# KRAGEN_DATABASE__URL=postgresql+asyncpg://kragen:secret@127.0.0.1:5432/kragen
# KRAGEN_AUTH__DISABLED=true
# KRAGEN_AUTH__DEV_USER_ID=00000000-0000-0000-0000-000000000001
# KRAGEN_STORAGE__ENDPOINT_URL=http://127.0.0.1:9000
# KRAGEN_STORAGE__ACCESS_KEY=minioadmin
# KRAGEN_STORAGE__SECRET_KEY=minioadmin
# KRAGEN_CHANNELS__OPENCLAW_ENABLED=false

# memory-mcp (Cursor long-term memory)
# MEMORY_MCP_DATABASE_URL=postgresql://kragen:secret@127.0.0.1:5432/kragen
# MEMORY_MCP_WORKSPACE_ID=00000000-0000-0000-0000-000000000000
